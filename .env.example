# Copy to .env.local and fill in values

# Backend API base URL
NEXT_PUBLIC_API_URL=https://api-v2.genohub.org/api/v1

# Server-side API key for SSE proxy (get from Settings page after login)
FAVOR_API_KEY=

# Google Analytics (optional)
GA_TRACKING_ID=

# Set "true" to enable; absent or any other value falls back to the flag's
# registered default. client checks are presentation only.
NEXT_PUBLIC_IGVF_ENABLED=false
