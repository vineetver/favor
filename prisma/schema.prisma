generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GeneSummary {
  id                  String   @id
  symbol              String   @unique
  ensemblGene         String?
  hgncId              String?
  ncbiGeneId          String?
  summary             String?
  model               String?  @default("gpt-4o-mini")
  reasoningEffort     String?
  maxCompletionTokens Int?
  error               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  status              String   @default("pending")

  @@index([ncbiGeneId])
  @@index([status])
  @@index([symbol])
}

model VariantSummary {
  id        String   @id
  vcf       String   @unique
  summary   String?
  status    String
  error     String?
  modelId   String   @default("gpt-4o-mini")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([status])
  @@index([vcf])
}
